# Production API base URL — baked into the bundle at BUILD time by `npm run build`.
# Must be the full https origin with NO trailing slash. It's the same origin as
# the site, so there is no CORS or mixed-content problem.
# Consumed by frontend/src/api/auth.ts (falls back to localhost:3000 if unset).
VITE_API_URL=https://preppilot.shop
