# PrepPilot — environment variables
#
# Two services read env files, and they read DIFFERENT ones:
#   backend/.env      → Database + Backend + AI + Twilio
#   python-api/.env   → AI + Scoring weights
#
# Copy this file to both locations and fill in the values you need:
#   cp .env.example backend/.env
#   cp .env.example python-api/.env

# ─── Database (backend) ──────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/preppilot

# ─── Backend ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Required. Generate with: openssl rand -base64 32
# Note: token lifetime is hardcoded to 24h in routes/auth.ts — not configurable.
JWT_SECRET=your_jwt_secret_here
# CORS origin for the Vite dev server. Default: http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
# Where the Python analysis service is reachable. Default: http://localhost:8001
PARSE_API_URL=http://localhost:8001

# ─── AI — Google Gemini (backend AND python-api) ─────────────
# Required by BOTH services. Note the name: GOOGLE_API_KEY, not GEMINI_API_KEY.
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here
# Optional. Default: gemini-3.1-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite
# Optional, python-api only. Default: 0
GEMINI_TEMPERATURE=0

# ─── Scoring weights (python-api) ────────────────────────────
# Optional — these are the defaults. Should sum to 1.0.
WEIGHT_SKILL=0.40
WEIGHT_EXPERIENCE=0.30
WEIGHT_CULTURE=0.20
WEIGHT_EDUCATION=0.10

# ─── Twilio WhatsApp Sandbox (backend, optional) ─────────────
# Leave unset to disable WhatsApp entirely — sends become a logged no-op
# and nothing else breaks.
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Default: whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# The sandbox join phrase shown on the connect page. Default: "join grew-worry"
TWILIO_SANDBOX_KEYWORD=join your-sandbox-code
